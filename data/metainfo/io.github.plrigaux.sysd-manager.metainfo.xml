  <metadata_license>CC0</metadata_license>
  <project_license>GPL-3.0+</project_license>
  <name comments="metainfo name">SysD Manager</name>
  <summary comments="metainfo summary">A user-friendly application to manage systemd's units</summary>
  <!--   <icon type="stock">io.github.plrigaux.sysd-manager</icon> -->
  <description>
    <p>
      Manage your Services, Timers, Sockets and other units. You can enable, disable, stop and
      start them. Also, you can view their config file and peak at their journal logs.
    </p>
  </description>
  <branding>
    <color type="primary" scheme_preference="light">#a1ba87</color>
